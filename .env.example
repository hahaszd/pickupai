## Server
PORT=3000
PUBLIC_BASE_URL=https://getpickupai.com.au

## Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local geographic number used to seed the first default tenant on startup
# and as the "from" number for simulated demo calls.
# Each tradie's actual dedicated voice number is stored in the database (tenants.twilio_number).
TWILIO_DEFAULT_VOICE_NUMBER=+612xxxxxxxx

# One or more mobile numbers (comma-separated) used to send SMS notifications
# to tradie owners after each call. Messages are sent round-robin across all numbers.
# Example with two numbers: +61412000111,+61412000222
TWILIO_SMS_NUMBERS=+614xxxxxxxx

## Business owner defaults (used as fallback; per-tenant values stored in DB)
OWNER_PHONE_NUMBER=+61xxxxxxxxx
ENABLE_WARM_TRANSFER=false
WARM_TRANSFER_ONLY_DURING_BUSINESS_HOURS=true
BUSINESS_TIMEZONE=Australia/Sydney
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=17:00

## Security
# IMPORTANT: Set TWILIO_VALIDATE_SIGNATURE=true in production to prevent webhook spoofing.
# This verifies that all /twilio/* webhook calls genuinely come from Twilio.
TWILIO_VALIDATE_SIGNATURE=false  # set to true in production
ADMIN_TOKEN=change-this-secret-token
STORE_FULL_TRANSCRIPT=true

## Email Notifications (optional — used alongside SMS for owner notifications)
# Configure an SMTP server to send email alerts for new leads. Transactional
# email services like Resend, Postmark, or SendGrid work well here.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxx
# SMTP_FROM=PickupAI <noreply@yourdomain.com>

## AI
OPENAI_API_KEY=sk-proj-...
OPENAI_VOICE=sage

## CRM Export (optional)
# AIRTABLE_API_TOKEN=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_NAME=Leads
#
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_WORKSHEET_NAME=Leads
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/google-service-account.json

## Call settings
# Maximum call duration before safety hangup (default: 300000 = 5 minutes)
# MAX_CALL_DURATION_MS=300000

## Data
# SQLite is used for local development (persisted to disk via SQLITE_PATH).
# For production on Railway: use PostgreSQL via DATABASE_URL.
# When DATABASE_URL is set, SQLITE_PATH is ignored.
SQLITE_PATH=./data/app.sqlite
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

## Stripe
# Stripe keys — switch from sk_test_ / pk_test_ to sk_live_ / pk_live_ when going live.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_PRICE_ID=price_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Founding customer coupon — create in Stripe Dashboard → Coupons ($50/mo off for 3 months).
# Remove or unset once the founding offer ends.
# STRIPE_FOUNDING_COUPON_ID=

## Demo pool — comma-separated Twilio numbers for live demos (optional)
# DEMO_POOL_NUMBERS=+612xxxxxxxx
# DEMO_POOL_NUMBER_SID=PNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

## Auto-configure Twilio webhooks on startup (set to "true" only for dev)
# TWILIO_AUTO_CONFIGURE_WEBHOOKS=false

## Google Analytics (optional — GA4 Measurement ID, e.g. G-XXXXXXXXXX)
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

## Seed tenant — auto-creates a default tenant with these credentials on first run (optional)
# SEED_EMAIL=admin@example.com
# SEED_PASSWORD=changeme123
